{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "left",
  "positionY": "top",
  "layer": "top",
  "control-center-margin-top": 10,
  "control-center-margin-left": 10,
  "control-center-margin-right": 0,
  "control-center-margin-bottom": 0,
  "control-center-width": 300,
  "cssPriority": "application",
  "skip-display": false,
  "timeout": 5,
  "timeout-low": 2,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "widgets": [
    "title",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-button": true
    },
    "dnd": {
      "text": "Do Not Disturb"
    }
  }
}
